# Machine-specific overrides (not committed). Included first so its
# host entries take precedence (SSH uses the first matching value).
Include ~/.ssh/config.local

Include ~/.ssh/conductor_config

# Added by OrbStack: 'orb' SSH host for Linux machines
Include ~/.orbstack/ssh/config

Include ~/.colima/ssh_config

# --- Specific hosts (must precede `Host *` so their IdentityAgent wins) ---

Host github.com
  HostName github.com
  User git
  IdentitiesOnly yes
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentityFile ~/.ssh/skysafe_github.pub
  IdentityFile ~/.ssh/id_ed25519_sk_rk

Host github-saegey
  HostName github.com
  User git
  IdentitiesOnly yes
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentityFile ~/.ssh/id_rsa_personal.pub

Host beelink
  HostName beelink
  User saegey
  IdentitiesOnly yes
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentityFile ~/.ssh/id_rsa_personal.pub

Host grooovenet
  HostName ssh-grooovenet.vinylplay.cc
  User ben
  ProxyCommand cloudflared access ssh --hostname %h

# --- Catch-all (1Password agent) ---

Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
