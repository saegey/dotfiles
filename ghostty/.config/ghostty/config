# Ghostty config for Adam

# Font
font-family = "JetBrains Mono"
font-size = 14
font-thicken = true
font-thicken-strength = 70

# Theme
theme = dark:Catppuccin Frappe,light:Catppuccin Latte
background-opacity = 0.96
background-blur-radius = 20

# Window
window-padding-x = 12
window-padding-y = 10
window-decoration = true
window-inherit-working-directory = true
macos-titlebar-style = tabs
quit-after-last-window-closed = true

# Notifications
notify-on-command-complete-timeout = 10

# Shell
command = /bin/zsh

# Cursor
cursor-style = block
cursor-style-blink = false

# Scrollback
scrollback-limit = 100000

# Clipboard
copy-on-select = false
clipboard-read = allow
clipboard-write = allow

# Mouse
mouse-hide-while-typing = true

# URLs
link-url = true

# macOS behavior
macos-option-as-alt = true
macos-non-native-fullscreen = false

# Keybinds
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+]=next_tab
keybind = cmd+shift+[=previous_tab
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+enter=toggle_fullscreen
keybind = cmd+k=clear_screen
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size